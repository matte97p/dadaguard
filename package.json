{
  "name": "dadaguard",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Dadaguard — the watchdog for your stack. Local-first: is my stack up AND coherent? across AWS + Doppler + Terraform.",
  "scripts": {
    "dev": "concurrently -n server,web -c green,cyan \"node --watch server/index.js\" \"vite\"",
    "server": "node server/index.js",
    "discover": "node scripts/discover.js",
    "check": "node scripts/check.js",
    "config:push": "node scripts/push-config.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "@aws-sdk/client-acm": "^3.1076.0",
    "@aws-sdk/client-auto-scaling": "^3.1075.0",
    "@aws-sdk/client-cloudfront": "^3.1076.0",
    "@aws-sdk/client-cloudtrail": "^3.1077.0",
    "@aws-sdk/client-cloudwatch": "^3.1075.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1076.0",
    "@aws-sdk/client-cost-explorer": "^3.1075.0",
    "@aws-sdk/client-dynamodb": "^3.1076.0",
    "@aws-sdk/client-ec2": "^3.1075.0",
    "@aws-sdk/client-ecs": "^3.1075.0",
    "@aws-sdk/client-eks": "^3.1076.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1075.0",
    "@aws-sdk/client-elasticache": "^3.1076.0",
    "@aws-sdk/client-eventbridge": "^3.1077.0",
    "@aws-sdk/client-iam": "^3.1076.0",
    "@aws-sdk/client-kinesis": "^3.1076.0",
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-organizations": "^3.1077.0",
    "@aws-sdk/client-rds": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-service-quotas": "^3.1076.0",
    "@aws-sdk/client-sfn": "^3.1076.0",
    "@aws-sdk/client-sns": "^3.1076.0",
    "@aws-sdk/client-sqs": "^3.1076.0",
    "@aws-sdk/client-ssm": "^3.1075.0",
    "@aws-sdk/client-sts": "^3.1077.0",
    "@aws-sdk/credential-providers": "^3.1075.0",
    "@xyflow/react": "^12.11.1",
    "antd": "^5.17.4",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^8.1.0"
  }
}
