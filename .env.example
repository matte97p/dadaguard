# Copia in .env e regola. Tutte opzionali: scegli UN modo per l'accesso AWS read-only.
# (Su EC2/ECS puoi lasciare tutto vuoto e usare il ruolo dell'istanza.)

# Porta su cui esporre la dashboard
PORT=3001

# Modalità DEMO: dati finti, ZERO connessione AWS. Per provarlo o registrare una demo.
# Mettilo a 1 e avvia: vedrai una flotta di esempio con tutti gli stati. Lascia vuoto per i dati reali.
DADAGUARD_DEMO=

# Opzione A — profilo da ~/.aws (montato dal docker-compose)
AWS_PROFILE=

# Opzione B — chiavi dirette
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Region di default per le chiamate (gli account in services.yaml possono sovrascriverla)
AWS_REGION=eu-central-1
